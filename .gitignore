# =============================================================================
# .NET / C# build artifacts
# =============================================================================
bin/
obj/
[Bb]in/
[Oo]bj/
*.dll
*.exe
*.pdb
*.cache
*.ilk
*.lib
*.exp
*.appx
*.appxbundle
*.msix
*.msixbundle

# =============================================================================
# NuGet
# =============================================================================
*.nupkg
*.snupkg
.nuget/
packages/
project.lock.json
project.assets.json
*.nuget.cache
*.nuget.dgspec.json

# =============================================================================
# IDEs
# =============================================================================
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.csproj.user
*.vbproj.user

# =============================================================================
# dnSpy / decompilation tools (download via tools/setup-dnspy.ps1)
# =============================================================================
dnSpy/
dnSpy32/
dnSpy64/

# =============================================================================
# Audit outputs (generated by skills at runtime)
# =============================================================================
audit-output/
*_audit/
surface/
route_mapper/
auth_audit/
trace/
specialized/
cross_analysis/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
pip-log.txt

# =============================================================================
# Node.js
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# OS files
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# =============================================================================
# Temporary / backup files
# =============================================================================
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# =============================================================================
# Secrets / credentials (NEVER commit)
# =============================================================================
*.pem
*.key
*.pfx
*.p12
appsettings.Development.json
appsettings.Local.json
secrets.json

# =============================================================================
# Large media / raw screenshots (keep docs/assets only)
# =============================================================================
*.png
*.jpg
*.jpeg
*.gif
!docs/assets/**/*.png
!docs/assets/**/*.jpg
!docs/assets/**/*.jpeg
!docs/assets/**/*.gif
